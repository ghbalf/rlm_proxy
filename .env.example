# Ollama connection (single host, used when no providers in config.json)
OLLAMA_BASE_URL=http://localhost:11434

# Legacy multi-host (comma-separated, prefer config.json providers instead)
# RLM_OLLAMA_HOSTS=http://machine1:11434,http://machine2:11434
RLM_OLLAMA_HOSTS=

# How often (seconds) to re-query providers for available models (0 = disable)
RLM_DISPATCHER_REFRESH_INTERVAL=60

# Root model for RLM code generation (must be a strong coder)
# Use "provider/model" to pin to a specific provider, e.g. "local/qwen3-coder-next"
# Sub model = whatever the user sends in the request
RLM_ROOT_MODEL=qwen3-coder-next

# RLM behaviour
# Prompts longer than this (chars) trigger RLM mode
RLM_THRESHOLD_CHARS=50000
# Max root LLM turns per request
RLM_MAX_ITERATIONS=20
# Max sub-LLM calls per request
RLM_MAX_SUB_CALLS=50
# Max chars sent to a sub-call
RLM_SUB_CALL_MAX_CHARS=500000
# Seconds per REPL code execution
RLM_EXEC_TIMEOUT=60

# Server
RLM_HOST=0.0.0.0
RLM_PORT=8881

# Short prompt passthrough (skip RLM for short prompts)
RLM_PASSTHROUGH_SHORT=true

# Performance
# Parallel sub-calls via llm_query_batch()
RLM_MAX_CONCURRENT_SUB_CALLS=4
# LRU cache entries for sub-call results
RLM_SUB_CALL_CACHE_SIZE=128
# Characters per token (for estimation)
RLM_TOKEN_ESTIMATE_RATIO=4.0
# Max estimated tokens per session (0 = unlimited)
RLM_TOKEN_BUDGET=0
# Max nesting depth for recursive sub-calls
RLM_MAX_SUB_CALL_DEPTH=3

# Authentication (empty = disabled)
RLM_API_KEY=

# Request queue
# Max simultaneous RLM sessions
RLM_MAX_CONCURRENT_SESSIONS=2
# Max queued requests before 429
RLM_MAX_QUEUE_SIZE=10

# Retry + circuit breaker
# Retries on transient failures
RLM_OLLAMA_MAX_RETRIES=3
# Base delay (seconds) for exponential backoff
RLM_OLLAMA_RETRY_BASE_DELAY=1.0
# Consecutive failures before circuit opens
RLM_CIRCUIT_BREAKER_THRESHOLD=5
# Seconds before circuit half-opens for probe
RLM_CIRCUIT_BREAKER_TIMEOUT=30

# History compaction
# Turns before LLM-summarized compaction
RLM_HISTORY_COMPACT_THRESHOLD=30

# Observability
RLM_METRICS_ENABLED=true
# Directory for JSONL session logs (empty = disabled)
RLM_TRAJECTORY_LOG_DIR=

# Prompt profiles (empty = auto-detect from model name)
RLM_PROMPT_PROFILE=
