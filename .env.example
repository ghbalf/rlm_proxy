# Ollama connection (single host, used when no providers in config.json)
OLLAMA_BASE_URL=http://localhost:11434

# Legacy multi-host (comma-separated, prefer config.json providers instead)
# RLM_OLLAMA_HOSTS=http://machine1:11434,http://machine2:11434
RLM_OLLAMA_HOSTS=

# How often (seconds) to re-query providers for available models (0 = disable)
RLM_DISPATCHER_REFRESH_INTERVAL=60

# Root model for RLM code generation (must be a strong coder)
# Use "provider/model" to pin to a specific provider, e.g. "local/qwen3-coder-next"
# Sub model = whatever the user sends in the request
RLM_ROOT_MODEL=qwen3-coder-next

# RLM behaviour
RLM_THRESHOLD_CHARS=50000    # prompts longer than this trigger RLM mode
RLM_MAX_ITERATIONS=20        # max root LLM turns per request
RLM_MAX_SUB_CALLS=50         # max sub-LLM calls per request
RLM_SUB_CALL_MAX_CHARS=500000 # max chars sent to a sub-call
RLM_EXEC_TIMEOUT=60          # seconds per REPL code execution

# Server
RLM_HOST=0.0.0.0
RLM_PORT=8881

# Short prompt passthrough (skip RLM for short prompts)
RLM_PASSTHROUGH_SHORT=true

# Performance
RLM_MAX_CONCURRENT_SUB_CALLS=4  # parallel sub-calls via llm_query_batch()
RLM_SUB_CALL_CACHE_SIZE=128     # LRU cache entries for sub-call results
RLM_TOKEN_ESTIMATE_RATIO=4.0    # characters per token (for estimation)
RLM_TOKEN_BUDGET=0               # max estimated tokens per session (0 = unlimited)
RLM_MAX_SUB_CALL_DEPTH=3         # max nesting depth for recursive sub-calls

# Authentication (empty = disabled)
RLM_API_KEY=

# Request queue
RLM_MAX_CONCURRENT_SESSIONS=2   # max simultaneous RLM sessions
RLM_MAX_QUEUE_SIZE=10            # max queued requests before 429

# Retry + circuit breaker
RLM_OLLAMA_MAX_RETRIES=3         # retries on transient failures
RLM_OLLAMA_RETRY_BASE_DELAY=1.0  # base delay (seconds) for exponential backoff
RLM_CIRCUIT_BREAKER_THRESHOLD=5  # consecutive failures before circuit opens
RLM_CIRCUIT_BREAKER_TIMEOUT=30   # seconds before circuit half-opens for probe

# History compaction
RLM_HISTORY_COMPACT_THRESHOLD=30 # turns before LLM-summarized compaction

# Observability
RLM_METRICS_ENABLED=true
RLM_TRAJECTORY_LOG_DIR=          # directory for JSONL session logs (empty = disabled)

# Prompt profiles (empty = auto-detect from model name)
RLM_PROMPT_PROFILE=
